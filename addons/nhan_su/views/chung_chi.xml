<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ===== TREE VIEW ===== -->
    <record id="view_chung_chi_tree" model="ir.ui.view">
        <field name="name">chung.chi.tree</field>
        <field name="model">chung_chi</field>
        <field name="arch" type="xml">
            <tree string="Danh sách chứng chỉ">
                <field name="ten_chung_chi"/>
                <field name="don_vi_cap"/>
                <field name="ngay_cap"/>
                <field name="ngay_het_han"/>
            </tree>
        </field>
    </record>

    <!-- ===== FORM VIEW ===== -->
    <record id="view_chung_chi_form" model="ir.ui.view">
        <field name="name">chung.chi.form</field>
        <field name="model">chung_chi</field>
        <field name="arch" type="xml">
            <form string="Chứng chỉ">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="ten_chung_chi" placeholder="Tên chứng chỉ"/>
                        </h1>
                    </div>

                    <group col="2" string="Thông tin chứng chỉ">
                        <field name="ten_chung_chi" required="1"/>
                        <field name="don_vi_cap"/>
                        <field name="ngay_cap"/>
                        <field name="ngay_het_han"/>
                    </group>

                    <group string="Mô tả">
                        <field name="mo_ta" nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Nhân viên có chứng chỉ này">
                            <field name="danh_sach_chung_chi_bang_cap_ids">
                                <tree>
                                    <field name="nhan_vien_id"/>
                                    <field name="ma_dinh_danh"/>
                                    <field name="ho_va_ten"/>
                                    <field name="ghi_chu"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===== SEARCH VIEW ===== -->
    <record id="view_chung_chi_search" model="ir.ui.view">
        <field name="name">chung.chi.search</field>
        <field name="model">chung_chi</field>
        <field name="arch" type="xml">
            <search>
                <field name="ten_chung_chi"/>
                <field name="don_vi_cap"/>
                <field name="ngay_cap"/>
                <field name="ngay_het_han"/>
            </search>
        </field>
    </record>

    <!-- ===== ACTION ===== -->
    <record id="action_chung_chi" model="ir.actions.act_window">
        <field name="name">Chứng chỉ / Bằng cấp</field>
        <field name="res_model">chung_chi</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_chung_chi_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có chứng chỉ nào.<br/>Nhấn "Tạo" để thêm chứng chỉ mới.
            </p>
        </field>
    </record>

</odoo>
