<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= TREE VIEW ================= -->
    <record id="view_phong_ban_tree" model="ir.ui.view">
        <field name="name">phong.ban.tree</field>
        <field name="model">phong_ban</field>
        <field name="arch" type="xml">
            <tree string="Danh sách phòng ban">
                <field name="ma_dinh_danh"/>
                <field name="ten_phong_ban"/>
            </tree>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_phong_ban_form" model="ir.ui.view">
        <field name="name">phong.ban.form</field>
        <field name="model">phong_ban</field>
        <field name="arch" type="xml">
            <form string="Phòng ban">
                <sheet>

                    <!-- TIÊU ĐỀ -->
                    <div class="oe_title">
                        <h1>
                            <field name="ten_phong_ban" placeholder="Tên phòng ban"/>
                        </h1>
                    </div>

                    <!-- THÔNG TIN PHÒNG BAN -->
                    <group col="2" string="Thông tin phòng ban">
                        <field name="ma_dinh_danh"/>
                        <field name="ten_phong_ban"/>
                        <field name="phong_ban_id"/>
                        <field name="truong_phong_id"/>
                        <field name="trang_thai"/>
                        <field name="ngay_thanh_lap"/>
                        <field name="so_luong_nhan_vien" readonly="1"/>
                    </group>
                    <group col="2" string="Thông tin liên hệ">
                        <field name="dia_chi"/>
                        <field name="so_dien_thoai"/>
                        <field name="email"/>
                    </group>
                    <group string="Mô tả">
                        <field name="mo_ta" nolabel="1"/>
                    </group>

                    <!-- ================= DANH SÁCH NHÂN VIÊN ================= -->
                    <notebook>
                        <page string="Nhân viên thuộc phòng ban">
                            <field name="nhan_vien_ids" widget="many2many_tags"/>
                            <field name="so_luong_nhan_vien" readonly="1"/>
                        </page>
                        <page string="Phòng ban con">
                            <field name="phong_ban_con_ids">
                                <tree>
                                    <field name="ma_dinh_danh"/>
                                    <field name="ten_phong_ban"/>
                                    <field name="so_luong_nhan_vien"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= SEARCH VIEW ================= -->
    <record id="view_phong_ban_search" model="ir.ui.view">
        <field name="name">phong.ban.search</field>
        <field name="model">phong_ban</field>
        <field name="arch" type="xml">
            <search>
                <field name="ma_dinh_danh"/>
                <field name="ten_phong_ban"/>
            </search>
        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_phong_ban" model="ir.actions.act_window">
        <field name="name">Phòng ban</field>
        <field name="res_model">phong_ban</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_phong_ban_search"/>
    </record>

</odoo>
