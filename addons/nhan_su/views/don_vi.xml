<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_don_vi_form" model="ir.ui.view">
            <field name="name">don_vi.form</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <form string="Đơn vị">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ten_don_vi" placeholder="Tên đơn vị"/>
                            </h1>
                        </div>
                        <group col="2" string="Thông tin đơn vị">
                            <field name="ma_don_vi" required="1"/>
                            <field name="ten_don_vi" required="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_don_vi_tree" model="ir.ui.view">
            <field name="name">don_vi.tree</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <tree string="Danh sách đơn vị">
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="don_vi_search" model="ir.ui.view">
            <field name="name">don_vi.search</field>
            <field name="model">don_vi</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm đơn vị">
                    <field name="ma_don_vi"/>
                    <field name="ten_don_vi"/>
                    <filter string="Mã đơn vị" name="group_by_ma" context="{'group_by': 'ma_don_vi'}"/>
                </search>
            </field>
        </record>

        <!-- Window Action -->
        <record id="action_don_vi" model="ir.actions.act_window">
            <field name="name">Đơn vị</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">don_vi</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="don_vi_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Chưa có đơn vị nào được tạo.<br/>
                    Nhấn "Tạo" để thêm đơn vị mới.
                </p>
            </field>
        </record>
    </data>
</odoo>